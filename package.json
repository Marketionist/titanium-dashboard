{
  "name": "titanium-dashboard",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.x.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Marketionist/titanium-dashboard"
  },
  "keywords": [
    "titanium dashboard",
    "titanium-dashboard",
    "Titanium Dashboard",
    "Titanium-Dashboard"
  ],
  "author": "Dmytro Shpakovskyi",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:mac": "tsc && vite build && electron-builder --mac",
    "build:win": "tsc && vite build && electron-builder --win",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "patch": "npm version patch -m \"Bump up package version to %s\" && git push && git push origin --tags && npm publish",
    "minor": "npm version minor -m \"Bump up package version to %s\" && git push && git push origin --tags && npm publish",
    "major": "npm version major -m \"Bump up package version to %s\" && git push && git push origin --tags && npm publish"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
